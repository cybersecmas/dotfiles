# Navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ~='cd ~'

# List
alias ls='ls --color=auto'
alias ll='ls -lah'
alias la='ls -A'

# Git
alias g='git'
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git pull'
alias glog='git log --oneline --graph --decorate'

# Editor
alias v='vim'

# Utilities
alias grep='grep --color=auto'
alias df='df -h'
alias du='du -sh'
alias cat='bat --style=plain'

# Reload shell
alias reload='source ~/.zshrc'
