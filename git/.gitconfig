[include]
	path = ~/.gitconfig.local

[core]
	editor          = vim
	excludesfile    = ~/.gitignore_global
	autocrlf        = input
	whitespace      = fix,space-before-tab,tab-in-indent,trailing-space

[init]
	defaultBranch = main

[push]
	default = current

[pull]
	rebase = false

[merge]
	tool = vimdiff

[color]
	ui = auto

[alias]
	st   = status
	co   = checkout
	br   = branch
	lg   = log --oneline --graph --decorate --all
	undo = reset --soft HEAD~1
	wip  = commit -am "WIP"
